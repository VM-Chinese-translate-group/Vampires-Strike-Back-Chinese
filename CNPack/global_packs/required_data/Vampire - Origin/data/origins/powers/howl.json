{
    "name": "power.origins.howl.name",
    "description": "power.origins.howl.description",
    "type": "origins:multiple",
    "go_down": {
        "type": "origins:active_self",
        "entity_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:change_resource",
                    "resource": "*:*_on_ground",
                    "change": -1
                },
                {
                    "type": "origins:apply_effect",
                    "effect": {
                        "effect": "minecraft:resistance",
                        "duration": 20,
                        "amplifier": 4
                    }
                },
                {
                    "type": "origins:apply_effect",
                    "effect": {
                        "effect": "minecraft:slowness",
                        "duration": 12,
                        "amplifier": 2
                    }
                },
                {
                    "type": "origins:apply_effect",
                    "effect": {
                        "effect": "minecraft:slowness",
                        "duration": 24,
                        "amplifier": 1
                    }
                },
                {
                    "type": "origins:apply_effect",
                    "effect": {
                        "effect": "minecraft:slowness",
                        "duration": 40,
                        "amplifier": 0
                    }
                }
            ]
        },
        "hud_render": {
            "should_render": true,
            "sprite_location": "origins:textures/gui/community/spiderkolo/resource_bar_02.png",
            "bar_index": 0
        },
        "key": {
            "key": "key.origins.secondary_active"
        },
        "cooldown": 100
    },
    "on_ground": {
        "type": "origins:resource",
        "min": 0,
        "max": 1,
        "start_value": 1,
        "hud_render": {
            "should_render": false
        },
        "max_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:spawn_particles",
                    "particle": {
                        "type": "minecraft:dust",
                        "params": "1 1 1 2"
                    },
                    "count": 128,
                    "speed": 4.3,
                    "force": false,
                    "spread": {
                        "x": 3.0,
                        "y": 0.5,
                        "z": 3.0
                    }
                },
                {
                    "type": "origins:play_sound",
                    "sound": "species:entity.bewereager.howl",
                    "volume": 1.2,
                    "pitch": 1.5
                },
                {
                    "type": "origins:apply_effect",
                    "effect": {
                        "effect": "minecraft:night_vision",
                        "duration": 30,
                        "amplifier": 0
                    }
                },
                {
                    "type": "origins:execute_command",
                    "command": "effect give @e[type=#vampires:humans] minecraft:glowing 1 0 true",
                    "permission_level": 4
                },
                {
                    "type": "origins:area_of_effect",
                    "radius": 4,
                    "bientity_action": {
                        "type": "origins:and",
                        "actions": [
                            {
                                "type": "origins:target_action",
                                "action": {
                                    "type": "origins:damage",
                                    "amount": 0,
                                    "source": {
                                        "name": "thrown.item"
                                    }
                                }
                            },
                            {
                                "type": "origins:add_velocity",
                                "z": 3.4,
                                "y": 0.6,
                                "set": true,
                                "space": "world"
                            }
                        ]
                    }
                },
                {
                    "type": "origins:area_of_effect",
                    "radius": 6,
                    "bientity_action": {
                        "type": "origins:and",
                        "actions": [
                            {
                                "type": "origins:target_action",
                                "action": {
                                    "type": "origins:damage",
                                    "amount": 0,
                                    "source": {
                                        "name": "thrown.item"
                                    }
                                }
                            },
                            {
                                "type": "origins:add_velocity",
                                "z": 2.6,
                                "y": 0.6,
                                "set": true,
                                "space": "world"
                            }
                        ]
                    }
                },
                {
                    "type": "origins:area_of_effect",
                    "radius": 8,
                    "bientity_action": {
                        "type": "origins:and",
                        "actions": [
                            {
                                "type": "origins:target_action",
                                "action": {
                                    "type": "origins:damage",
                                    "amount": 0,
                                    "source": {
                                        "name": "thrown.item"
                                    }
                                }
                            },
                            {
                                "type": "origins:add_velocity",
                                "z": 1.8,
                                "y": 0.6,
                                "set": true,
                                "space": "world"
                            }
                        ]
                    }
                }
            ]
        }
    },
    "touching_ground": {
        "type": "origins:action_over_time",
        "interval": 1,
        "entity_action": {
            "type": "origins:change_resource",
            "resource": "*:*_on_ground",
            "change": 1
        }
    }
}